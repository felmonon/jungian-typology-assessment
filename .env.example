# TypeJung - Environment Variables

# ======================
# Analytics & Monitoring
# ======================

# Google Analytics 4 Measurement ID
# Get from: Google Analytics -> Admin -> Data Streams -> Web
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry DSN for error monitoring
# Get from: Sentry -> Project Settings -> Client Keys (DSN)
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ======================
# Database & Auth
# ======================

# Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Postgres connection string for the Express/Drizzle server path
DATABASE_URL=postgresql://user:password@host:5432/database

# Session signing secret used by both Express and Vercel auth routes
SESSION_SECRET=replace_with_a_long_random_secret

# Optional Google OAuth credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ======================
# Email Delivery
# ======================

# Resend lifecycle/result emails. RESEND_FROM_EMAIL must be a verified sender.
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL="TypeJung <results@your-domain.com>"

# ======================
# Stripe API Keys
# ======================
# Get these from https://dashboard.stripe.com/apikeys

# Server-side (Vercel Functions) - Keep SECRET!
STRIPE_SECRET_KEY=sk_live_your_secret_key_here

# Server resolves Checkout prices by tier. Never accept price IDs from the browser.
STRIPE_INSIGHT_PRICE_ID=price_your_insight_price_id_here
STRIPE_MASTERY_PRICE_ID=price_your_mastery_price_id_here

# Webhook secret (get this after setting up webhook in Stripe Dashboard)
# Go to https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ======================
# AI Features
# ======================

# Google Gemini API Key (for AI type coach)
GEMINI_API_KEY=your_gemini_api_key_here
