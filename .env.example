# Jungian Typology Assessment - Environment Variables

# ======================
# Analytics & Monitoring
# ======================

# Google Analytics 4 Measurement ID
# Get from: Google Analytics -> Admin -> Data Streams -> Web
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry DSN for error monitoring
# Get from: Sentry -> Project Settings -> Client Keys (DSN)
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ======================
# Stripe API Keys
# ======================
# Get these from https://dashboard.stripe.com/apikeys

# Server-side (Vercel Functions) - Keep SECRET!
STRIPE_SECRET_KEY=sk_live_your_secret_key_here

# Client-side (exposed to browser)
VITE_STRIPE_PUBLIC_KEY=pk_live_your_public_key_here

# Create a price in Stripe Dashboard and paste the ID here
VITE_STRIPE_PRICE_ID=price_your_price_id_here

# Webhook secret (get this after setting up webhook in Stripe Dashboard)
# Go to https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ======================
# AI Features
# ======================

# Google Gemini API Key (for AI type coach)
GEMINI_API_KEY=your_gemini_api_key_here
