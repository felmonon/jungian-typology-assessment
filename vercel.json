{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "crons": [
    {
      "path": "/api/auth/discount-followups",
      "schedule": "17 14 * * *"
    },
    {
      "path": "/api/recovery-emails",
      "schedule": "23 15 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/blog/:slug/",
      "destination": "/blog/:slug",
      "permanent": true
    },
    {
      "source": "/functions/:fn/",
      "destination": "/functions/:fn",
      "permanent": true
    },
    {
      "source": "/types/:type/",
      "destination": "/types/:type",
      "permanent": true
    },
    {
      "source": "/assessment%3Fsource=:source",
      "destination": "/assessment?source=:source",
      "permanent": true
    },
    {
      "source": "/%3Futm_source=:source",
      "destination": "/?utm_source=:source",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/stripe/webhook",
      "destination": "/api/webhook"
    },
    {
      "source": "/api/lifecycle-email",
      "destination": "/api/auth/lifecycle-email"
    },
    {
      "source": "/api/recovery-emails",
      "destination": "/api/auth/recovery-emails"
    },
    {
      "source": "/api/profile",
      "destination": "/api/auth/profile"
    },
    {
      "source": "/api/auth/google/callback",
      "destination": "/api/auth/google-callback"
    },
    {
      "source": "/assessment",
      "destination": "/assessment/index.html"
    },
    {
      "source": "/learn",
      "destination": "/learn/index.html"
    },
    {
      "source": "/pricing",
      "destination": "/pricing/index.html"
    },
    {
      "source": "/checkout/insight",
      "destination": "/checkout/insight/index.html"
    },
    {
      "source": "/checkout/mastery",
      "destination": "/checkout/mastery/index.html"
    },
    {
      "source": "/leaderboard",
      "destination": "/leaderboard/index.html"
    },
    {
      "source": "/about",
      "destination": "/about/index.html"
    },
    {
      "source": "/jungian-test",
      "destination": "/jungian-test/index.html"
    },
    {
      "source": "/mbti-alternative",
      "destination": "/mbti-alternative/index.html"
    },
    {
      "source": "/mbti-mistype-test",
      "destination": "/mbti-mistype-test/index.html"
    },
    {
      "source": "/inferior-function-test",
      "destination": "/inferior-function-test/index.html"
    },
    {
      "source": "/cognitive-function-test",
      "destination": "/cognitive-function-test/index.html"
    },
    {
      "source": "/cognitive-functions-test",
      "destination": "/cognitive-functions-test/index.html"
    },
    {
      "source": "/cognitive-functions-quiz",
      "destination": "/cognitive-functions-quiz/index.html"
    },
    {
      "source": "/creator-preview",
      "destination": "/creator-preview/index.html"
    },
    {
      "source": "/infj-vs-infp-test",
      "destination": "/infj-vs-infp-test/index.html"
    },
    {
      "source": "/intj-vs-intp-test",
      "destination": "/intj-vs-intp-test/index.html"
    },
    {
      "source": "/mbti-keeps-changing",
      "destination": "/mbti-keeps-changing/index.html"
    },
    {
      "source": "/jungian-cognitive-functions-test",
      "destination": "/jungian-cognitive-functions-test/index.html"
    },
    {
      "source": "/jungian-typology",
      "destination": "/jungian-typology/index.html"
    },
    {
      "source": "/cognitive-functions",
      "destination": "/cognitive-functions/index.html"
    },
    {
      "source": "/shadow-work-test",
      "destination": "/shadow-work-test/index.html"
    },
    {
      "source": "/functions/:fn",
      "destination": "/functions/:fn/index.html"
    },
    {
      "source": "/types/:type",
      "destination": "/types/:type/index.html"
    },
    {
      "source": "/blog",
      "destination": "/blog/index.html"
    },
    {
      "source": "/blog/:slug",
      "destination": "/blog/:slug.html"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/auth",
      "destination": "/index.html"
    },
    {
      "source": "/profile",
      "destination": "/index.html"
    },
    {
      "source": "/settings",
      "destination": "/index.html"
    },
    {
      "source": "/results",
      "destination": "/index.html"
    },
    {
      "source": "/success",
      "destination": "/index.html"
    },
    {
      "source": "/share/:slug",
      "destination": "/index.html"
    },
    {
      "source": "/admin",
      "destination": "/index.html"
    },
    {
      "source": "/history",
      "destination": "/index.html"
    },
    {
      "source": "/privacy",
      "destination": "/index.html"
    },
    {
      "source": "/terms",
      "destination": "/index.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/share/:slug",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/content.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).svg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
